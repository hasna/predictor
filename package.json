{
  "name": "@hasna/predictor",
  "version": "0.0.6",
  "description": "Swarm intelligence prediction engine \u2014 multi-agent simulation, persona generation, social dynamics, emergent behavior analysis",
  "type": "module",
  "bin": {
    "predictor": "./src/cli/index.ts",
    "predictor-mcp": "./src/mcp/index.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./mcp": "./src/mcp/index.ts"
  },
  "files": [
    "src",
    "LICENSE"
  ],
  "scripts": {
    "dev": "bun run src/cli/index.ts",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "typecheck": "tsc --noEmit",
    "mcp": "bun run src/mcp/index.ts",
    "postinstall": "mkdir -p $HOME/.hasna/predictor 2>/dev/null || true"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "dependencies": {
    "@hasna/cloud": "^0.1.0",
    "@hasna/researcher": "^0.1.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "commander": "^13.1.0",
    "openai": "^4.85.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "license": "Apache-2.0",
  "author": "Andrei Hasna <andrei@hasna.com>",
  "keywords": [
    "predictor",
    "swarm-intelligence",
    "multi-agent",
    "simulation",
    "prediction",
    "social-dynamics",
    "emergent-behavior",
    "ai",
    "llm"
  ]
}